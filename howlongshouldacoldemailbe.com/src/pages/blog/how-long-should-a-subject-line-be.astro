<Base
  title="How Long Should a Cold Email Subject Line Be?"
  description="Keep cold email subject lines at 21–40 characters — roughly 3–5 words. That range survives mobile truncation, reads like a human wrote it, and outperforms both one-word teasers and marketing-length subjects in Sales.co platform data."
  schema={schema}
