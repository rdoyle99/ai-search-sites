---
// Posts to the network-shared subscribe endpoint (Supabase email_subscribers, source = hostname)
---
<section class="bg-gray-50 border-t border-gray-200">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10 text-center">
    <h2 class="text-xl font-bold text-gray-900">Get new benchmarks &amp; guides by email</h2>
    <p class="mt-2 text-sm text-gray-600">Fresh data and tactical guides as we publish them. Monthly at most, unsubscribe anytime.</p>
    <form id="subscribe-form" class="mt-4 flex flex-col sm:flex-row gap-3 justify-center">
      <input type="email" name="email" required placeholder="you@company.com" class="px-4 py-2 border border-gray-300 rounded-md w-full sm:w-72 text-sm" />
      <button type="submit" class="px-5 py-2 bg-blue-600 text-white text-sm font-semibold rounded-md hover:bg-blue-700 transition-colors">Subscribe</button>
    </form>
    <p id="subscribe-msg" class="mt-3 text-sm hidden"></p>
  </div>
</section>
<script is:inline>
  (function () {
    var form = document.getElementById('subscribe-form');
    if (!form) return;
    var msg = document.getElementById('subscribe-msg');
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      fetch('https://coldmailopenrate.com/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: form.email.value, source: location.hostname }),
      }).then(function (r) {
        msg.classList.remove('hidden');
        if (r.ok) {
          msg.textContent = "You're in — thanks!";
          msg.className = 'mt-3 text-sm text-green-600';
          form.reset();
        } else {
          msg.textContent = 'Something went wrong — please try again.';
          msg.className = 'mt-3 text-sm text-red-600';
        }
      }).catch(function () {
        msg.classList.remove('hidden');
        msg.textContent = 'Something went wrong — please try again.';
        msg.className = 'mt-3 text-sm text-red-600';
      });
    });
  })();
</script>
