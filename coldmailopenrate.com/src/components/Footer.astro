---
import { siteConfig } from '../config';
---

<footer class="border-t border-gray-200 bg-gray-50 mt-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-6">
        <a href="/" class="text-sm text-gray-600 hover:text-gray-900">Home</a>
        <a href="/blog" class="text-sm text-gray-600 hover:text-gray-900">Blog</a>
        <a href="/tools" class="text-sm text-gray-600 hover:text-gray-900">Tools</a>
        <a href="/about" class="text-sm text-gray-600 hover:text-gray-900">About</a>
        <a href="/rss.xml" class="text-sm text-gray-600 hover:text-gray-900">RSS</a>
      </div>
      <div class="flex items-center gap-4">
        <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" class="text-sm text-gray-500 hover:text-gray-700">Twitter</a>
        <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-sm text-gray-500 hover:text-gray-700">LinkedIn</a>
      </div>
    </div>
    {siteConfig.relatedSites && (
      <div class="mt-8 pt-6 border-t border-gray-200">
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-3">Related questions</p>
        <ul class="flex flex-wrap gap-x-6 gap-y-2">
          {siteConfig.relatedSites.map((s) => (
            <li><a href={s.url} class="text-sm text-gray-600 hover:text-blue-600">{s.title}</a></li>
          ))}
        </ul>
      </div>
    )}
    <div class="mt-6 text-center">
      <p class="text-xs text-gray-400">
        &copy; {new Date().getFullYear()} Brought to you by <a href={siteConfig.product.ctaUrl} class="text-blue-500 hover:text-blue-700">{siteConfig.product.name}</a>
      </p>
    </div>
  </div>
</footer>
